;; zot-pull-scan/run.test.tlisp — (deftest …) smoke for the faucet gate logic
;; (severity classification + admit/reject decision + coarse count), run via
;; tatara-script --test by the tlisp-test action.

(deftest "severity-rank orders the trivy severity ladder"
  (assert (> (severity-rank "CRITICAL") (severity-rank "HIGH")) "CRITICAL > HIGH")
  (assert (> (severity-rank "HIGH") (severity-rank "MEDIUM")) "HIGH > MEDIUM")
  (assert (> (severity-rank "MEDIUM") (severity-rank "LOW")) "MEDIUM > LOW")
  (assert (= (severity-rank "none") 0) "none == 0")
  (assert (= (severity-rank "garbage") 0) "unknown == 0"))

(deftest "classify-severity picks the highest present severity"
  (assert (equal? (classify-severity "{\"Severity\":\"HIGH\"}") "HIGH") "single HIGH")
  (assert (equal? (classify-severity "\"Severity\":\"LOW\",\"Severity\":\"CRITICAL\"") "CRITICAL")
          "CRITICAL wins over LOW")
  (assert (equal? (classify-severity "{\"Results\":[]}") "none") "clean scan -> none"))

(deftest "rejects? gates admission at/above the threshold; none never rejects"
  (assert (rejects? "CRITICAL" "HIGH") "CRITICAL rejected at HIGH gate")
  (assert (rejects? "HIGH" "HIGH") "HIGH rejected at HIGH gate (>=)")
  (assert (not (rejects? "MEDIUM" "HIGH")) "MEDIUM admitted at HIGH gate")
  (assert (not (rejects? "none" "HIGH")) "clean image admitted")
  (assert (not (rejects? "CRITICAL" "none")) "fail-on=none never rejects"))

(deftest "count-occurrences is a pure (no-shell) substring count"
  (assert (= (count-occurrences "\"Severity\":x\"Severity\":y" "\"Severity\":") 2)
          "two Severity keys")
  (assert (= (count-occurrences "clean" "\"Severity\":") 0) "none present")
  (assert (= (count-occurrences "anything" "") 0) "empty needle -> 0"))
