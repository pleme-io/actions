;; dependabot-trigger/run.tlisp

(define eco (env-get "PACKAGE_ECOSYSTEM" "all"))
(define repo (env-required "GITHUB_REPOSITORY"))

(define r (exec-capture "gh" "api" "--method" "POST"
            (string-append "repos/" repo "/dependabot/updates")
            "-f" (string-append "package-ecosystem=" eco)))

(cond
  ((= (status-of r) 0) (append-output "triggered=true") (exit 0))
  (else (append-output "triggered=false") (exit 1)))
