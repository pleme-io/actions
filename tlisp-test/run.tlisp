;; tlisp-test/run.tlisp — discover + run every *.test.tlisp via tatara-script's
;; canonical --test mode. Each test runs as a single program:
;;
;;   <stdlib> + <dir>/<base>.tlisp (the unit) + <dir>/<base>.test.tlisp (tests)
;;
;; with TLISP_TEST=1 so the unit-under-test DEFINES its functions but SKIPS its
;; main (every testable action gates its main on (env-get "TLISP_TEST")). The
;; test file's (deftest …) forms then run against those definitions; an
;; (assert COND MSG) raises on failure so the deftest reports ✘ and the file
;; exits non-zero. This action fails the gate if ANY test file fails.
;;
;; No shell beyond a single `find` glue line — the orchestration (concat,
;; child invocation, aggregation) is tatara-lisp; exec-capture is the typed
;; subprocess surface. tatara-script is on PATH (the tatara-script@v1 step
;; that runs this script installed it there).

(define stdlib-path "_tlisp-stdlib/stdlib.tlisp")
(define child-tmp "/tmp/tlisp-test-current.tlisp")

(define (find-test-files)
  (let* ((r (exec-capture "sh" "-c"
              "find . -type f -name '*.test.tlisp' -not -path './.git/*' -not -path './target/*' -not -path './node_modules/*' | sort"))
         (out (string-trim (stdout-of r))))
    (if (equal? out "") (list) (string-split out "\n"))))

;; <dir>/<base>.test.tlisp -> <dir>/<base>.tlisp
(define (unit-of test-file) (string-replace test-file ".test.tlisp" ".tlisp"))

;; Read the stdlib once — prepended to every test program so the unit + test
;; see status-of / append-output / TOML helpers / etc. Use the checked-out
;; copy when present (the actions repo); otherwise fetch the canonical one so
;; this action works in any consumer repo.
(define stdlib-src
  (cond
    ((path-exists? stdlib-path) (read-file stdlib-path))
    (else
     (stdout-of (exec-capture "curl" "-sL"
       "https://raw.githubusercontent.com/pleme-io/actions/main/_tlisp-stdlib/stdlib.tlisp")))))

;; Run one test file. Returns 0 if every (deftest …) passed, non-zero otherwise.
(define (run-one test-file)
  (let ((unit (unit-of test-file)))
    (cond
      ((not (path-exists? unit))
       (log-error (string-append "tlisp-test: no unit-under-test for " test-file
                                 " (expected " unit ")"))
       1)
      (else
       (write-file child-tmp
                   (string-append stdlib-src "\n"
                                  (read-file unit) "\n"
                                  (read-file test-file)))
       ;; Gate the unit's main + give it a throwaway GITHUB_OUTPUT so a
       ;; top-level (env-required "GITHUB_OUTPUT") doesn't abort. env-set
       ;; plumbs both into the child process. The runner's own append-output
       ;; uses the stdlib's GITHUB_OUTPUT captured at load, so it is unaffected.
       (env-set "TLISP_TEST" "1")
       (env-set "GITHUB_OUTPUT" "/tmp/tlisp-test-child-output")
       (let* ((r (exec-capture "tatara-script" "--test" child-tmp))
              (s (status-of r)))
         (log-info (string-append "── " test-file (if (= s 0) "  [PASS]" "  [FAIL]")))
         (for-each (lambda (ln) (log-info (string-append "    " ln)))
                   (filter (lambda (l) (not (equal? l "")))
                           (string-split (string-append (stdout-of r) "\n" (stderr-of r)) "\n")))
         s)))))

(define (run-all files fails)
  (cond
    ((null? files) fails)
    (else (run-all (cdr files) (if (= (run-one (car files)) 0) fails (+ fails 1))))))

(define test-files (find-test-files))
(log-info (string-append "tlisp-test: " (string-format "{}" (length test-files)) " test file(s)"))

(define failures (run-all test-files 0))
(append-output (string-append "test-files=" (string-format "{}" (length test-files))))
(append-output (string-append "failed-files=" (string-format "{}" failures)))
(cond
  ((= failures 0)
   (log-info (string-append "tlisp-test: all " (string-format "{}" (length test-files)) " file(s) passed"))
   (exit 0))
  (else
   (log-error (string-append "tlisp-test: " (string-format "{}" failures) " file(s) failed"))
   (exit 1)))
