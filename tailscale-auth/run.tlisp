;; tailscale-auth/run.tlisp

(define host-r (exec-capture "sudo" "tailscale" "status" "--self=true" "--json"))
(let* ((jq-r (exec-capture "sh" "-c"
               (string-append "echo '" (string-replace (stdout-of host-r) "'" "'"'"'")
                              "' | jq -r '.Self.HostName'")))
       (host (string-trim (stdout-of jq-r))))
  (append-output (string-append "hostname=" host))
  (exit 0))
