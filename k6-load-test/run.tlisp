;; k6-load-test/run.tlisp

(define script (env-required "SCRIPT"))
(define vus (env-get "VUS" "10"))
(define dur (env-get "DURATION" "30s"))

;; Nix-installed, not apt (theory/NIX-HARDENING.md §VI) -- exact-pinned to
;; nixos-24.05, not an ambient apt repo whose signing key/package version
;; can change under us. The "Install Nix" step in action.yml already wired
;; nix onto PATH.
(exec-check "nix" "profile" "install" "github:NixOS/nixpkgs/nixos-24.05#k6")

(define r (exec-capture "k6" "run"
            "--vus" vus
            "--duration" dur
            "--summary-export=k6-summary.json"
            script))

(append-output "summary-path=k6-summary.json")
(cond
  ((= (status-of r) 0) (append-output "passed=true") (exit 0))
  (else (append-output "passed=false") (exit 1)))
