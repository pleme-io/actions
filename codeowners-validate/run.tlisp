;; codeowners-validate/run.tlisp — tlisp+stdlib body

(define fail-on (env-get "FAIL_ON_UNOWNED" "false"))

(cond
  ((not (or (path-exists? ".github/CODEOWNERS")
            (path-exists? "CODEOWNERS")
            (path-exists? "docs/CODEOWNERS")))
   (log-error "no CODEOWNERS file found")
   (append-output "unowned-count=0")
   (exit 1)))

;; Nix-installed, not runtime `go install ...@latest` (theory/NIX-HARDENING.md
;; §VI) -- the old install target never actually resolved (upstream's go.mod
;; has never declared a `/v2` module suffix at any released tag) and its
;; trailing `2>/dev/null || true` silently swallowed that failure. Exact-
;; pinned to v0.7.4 via hardened-images' own `codeownersValidatorPkg`
;; (a plain buildGoModule, not wrapped as a container image) rather than an
;; unpinned/floating install target. `nix profile install` puts the binary
;; on PATH for the rest of this script (the "Install Nix" step in action.yml
;; already ran DeterminateSystems/nix-installer-action, wiring nix itself
;; onto PATH).
(exec-check "nix" "profile" "install" "github:pleme-io/hardened-images#codeownersValidatorPkg")

(define r (exec-capture "codeowners-validator" "--repository" "."))
(define out (stdout-of r))

(define unowned-r
  (exec-capture "sh" "-c"
    (string-append "echo '" (string-replace out "'" "'"'"'")
                   "' | grep -c 'unowned' || echo 0")))
(define unowned (string-trim (stdout-of unowned-r)))

(append-output (string-append "unowned-count=" unowned))

(cond
  ((and (equal? fail-on "true") (not (equal? unowned "0"))) (exit 1))
  (else (exit 0)))
