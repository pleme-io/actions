;; _tlisp-stdlib/stdlib.test.tlisp — (deftest …) tests for the shared stdlib's
;; TOML helpers, run by the tlisp-test action via tatara-script --test. The
;; stdlib IS the unit-under-test; it is pure (no main), so no TLISP_TEST gate
;; is needed. These lock in the array-field-as-section + rust-version-substring
;; bugfix that now underpins rust-workspace-bump + rust-workspace-publish +
;; cargo-publish-each-member (all read versions through cargo-workspace-version
;; / toml-read-field).

(deftest "line-is-section-header?: a bracket with no '=' — array fields are NOT headers"
  (assert (line-is-section-header? "[workspace.package]") "real section header")
  (assert (line-is-section-header? "  [package]  ") "trimmed section header")
  (assert (not (line-is-section-header? "keywords = [\"a\", \"b\"]")) "array-valued field is NOT a header")
  (assert (not (line-is-section-header? "version = \"1.0\"")) "plain field is not a header")
  (assert (not (line-is-section-header? "# see [lib] below")) "bracketed COMMENT is NOT a header (kazari 2026-07-21)")
  (assert (not (line-is-section-header? "  # a [b] c")) "trimmed bracketed comment is NOT a header"))

(deftest "line-assigns-field?: exact field name, not a substring"
  (assert (line-assigns-field? "version = \"1.0\"" "version") "version assigns version")
  (assert (line-assigns-field? "  version=\"1.0\"" "version") "tight/trimmed still assigns version")
  (assert (not (line-assigns-field? "rust-version = \"1.89\"" "version")) "rust-version is NOT version"))

(deftest "line-is-named-section?: exact, not subsection or array value"
  (assert (line-is-named-section? "[package]" "[package]") "exact section matches")
  (assert (not (line-is-named-section? "[package.metadata.docs.rs]" "[package]")) "subsection is not [package]")
  (assert (not (line-is-named-section? "keywords = [\"package\"]" "[package]")) "array value is not a section"))

(deftest "extract-quoted-value: double + single quotes"
  (assert (equal? (extract-quoted-value "version = \"1.2.3\"") "1.2.3") "double-quoted value")
  (assert (equal? (extract-quoted-value "name = 'foo'") "foo") "single-quoted value"))

(deftest "toml-read-field reads version past an array field + a rust-version trap"
  (let ((p "/tmp/stdlib-test-cargo.toml"))
    (write-file p "[workspace.package]\nkeywords = [\"x\", \"y\"]\nversion = \"4.5.6\"\nrust-version = \"1.89.0\"\n")
    (assert (equal? (toml-read-field p "[workspace.package]" "version") "4.5.6")
            "reads 4.5.6 despite array field above + rust-version below")))

(deftest "toml-read-field stops at the next section (does not leak across)"
  (let ((p "/tmp/stdlib-test-cargo2.toml"))
    (write-file p "[package]\nname = \"a\"\n\n[dependencies]\nversion = \"9.9.9\"\n")
    (assert (equal? (toml-read-field p "[package]" "version") "")
            "no version in [package] — must not read [dependencies].version")))

(deftest "toml-read-field reads version past a bracketed [package] comment (kazari 2026-07-21)"
  ;; The recurring regression: a legal [package] comment that CONTAINS a bracket
  ;; (e.g. `# … (see [lib] below)`) was mis-read as a new section header, so the
  ;; walker left [package] before reaching `version` → cargo-bump reported
  ;; "package.version not found". The published-name-collision fix (renaming
  ;; kazari → pleme-io-kazari with an explanatory bracketed comment) tripped it.
  (let ((p "/tmp/stdlib-test-cargo3.toml"))
    (write-file p (string-append
                    "[package]\n"
                    "# the lib name stays `kazari` (see [lib] below)\n"
                    "name = \"pleme-io-kazari\"\n"
                    "version = \"0.1.3\"\n"
                    "\n"
                    "[lib]\n"
                    "name = \"kazari\"\n"))
    (assert (equal? (toml-read-field p "[package]" "version") "0.1.3")
            "a [package] comment containing a bracket must not end the section early")))

;; ── publishability preflight — the false-green seal ──────────────
;; A git dep (or a versionless path dep) in a SHIPPED dep table makes a crate
;; permanently unpublishable to crates.io; undetected it defers GREEN forever
;; (sui-spec froze at 0.1.118, 2026-07-21). These lock the DETECTION and, just
;; as load-bearing, the NO-FALSE-POSITIVE cases — a clean manifest MUST pass or
;; wiring the preflight into the publish action would red-fail real publishes.

(deftest "manifest-publish-blockers: detects a git dep in a shipped table (the sui-spec bug)"
  (assert (not (manifest-publishable?
                 "[package]\nname = \"sui-spec\"\n\n[dependencies]\nkazari = { git = \"https://github.com/pleme-io/kazari\", rev = \"abc\" }\nserde = \"1\"\n"))
          "a [dependencies] git dep is a blocker")
  (assert (= 1 (length (manifest-publish-blockers
                         "[package]\n[dependencies]\nkazari = { git = \"https://x\" }\n")))
          "exactly one blocker for one git dep"))

(deftest "manifest-publish-blockers: detects a versionless path dep in a shipped table"
  (assert (not (manifest-publishable?
                 "[package]\n[dependencies]\nfoo = { path = \"../foo\" }\n"))
          "a path dep with no version is a blocker")
  (assert (manifest-publishable?
            "[package]\n[dependencies]\nfoo = { path = \"../foo\", version = \"0.1\" }\n")
          "a path dep WITH a version is fine (a common publish pattern)"))

(deftest "manifest-publish-blockers: dev-dependencies are EXEMT (stripped on publish)"
  (assert (manifest-publishable?
            "[package]\nname = \"x\"\n\n[dependencies]\nserde = \"1\"\n\n[dev-dependencies]\nhelper = { git = \"https://x\" }\n")
          "a git dev-dependency does NOT block publish"))

(deftest "manifest-publish-blockers: NO false positives on a clean real-shaped manifest"
  ;; version deps, a workspace dep, repository= in [package], a bracketed
  ;; comment, a target table, a [lib] — all clean. MUST be publishable.
  (assert (manifest-publishable?
            (string-append
              "[package]\n"
              "name = \"pleme-io-kazari\"\n"
              "# the lib name stays `kazari` (see [lib] below)\n"
              "version = \"0.1.3\"\n"
              "repository = \"https://github.com/pleme-io/kazari\"\n"
              "\n"
              "[lib]\nname = \"kazari\"\n"
              "\n"
              "[dependencies]\n"
              "irodori = \"0.2\"\n"
              "serde = { version = \"1\", features = [\"derive\"] }\n"
              "sui-compat.workspace = true\n"
              "\n"
              "[target.'cfg(unix)'.dependencies]\n"
              "libc = \"0.2\"\n"
              "\n"
              "[dev-dependencies]\n"
              "tempfile = \"3\"\n"))
          "a clean manifest with version/workspace/target deps must NOT be flagged"))

(deftest "manifest-publish-blockers: target dep tables ship (a git dep there IS caught)"
  (assert (not (manifest-publishable?
                 "[package]\n[target.'cfg(unix)'.dependencies]\nfoo = { git = \"https://x\" }\n"))
          "a git dep in a [target.*.dependencies] table blocks")
  (assert (manifest-publishable?
            "[package]\n[target.'cfg(unix)'.dev-dependencies]\nfoo = { git = \"https://x\" }\n")
          "but a [target.*.dev-dependencies] git dep is exempt"))

(deftest "manifest-publish-blockers: a comment mentioning git is not a blocker"
  (assert (manifest-publishable?
            "[package]\n[dependencies]\n# clone via git = \"…\" during dev only\nserde = \"1\"\n")
          "a comment that mentions git= must not be read as a git dep"))
