;; pleme-io · _tlisp-stdlib/stdlib.tlisp
;;
;; Shared helper library prepended to each action's run.tlisp by
;; the action.yml's "Load run.tlisp" step. Holds every primitive
;; that appeared in ≥2 actions as of the v0.13.x release line.
;;
;; ────────────────────────────────────────────────────────────────
;; Adoption pattern for an action's action.yml:
;; ────────────────────────────────────────────────────────────────
;;
;;    - name: Load stdlib + run.tlisp
;;      id: src
;;      shell: bash
;;      run: |
;;        {
;;          echo 'script<<TLISP_EOF'
;;          # Resolve stdlib via the calling repo's checked-out
;;          # copy of pleme-io/actions, or curl from the v1 ref:
;;          curl -sL https://raw.githubusercontent.com/pleme-io/actions/main/_tlisp-stdlib/stdlib.tlisp
;;          echo
;;          cat ${{ github.action_path }}/run.tlisp
;;          echo 'TLISP_EOF'
;;        } >> "$GITHUB_OUTPUT"
;;
;;    - uses: pleme-io/actions/tatara-script@v1
;;      with: { script: ${{ steps.src.outputs.script }} }
;;
;; ────────────────────────────────────────────────────────────────
;; Conventions
;; ────────────────────────────────────────────────────────────────
;; - Every helper is pure (no side effects) except those whose
;;   names contain `!` (mutators) or those clearly named for
;;   side effects (`append-output`, `configure-git-bot`).
;; - Every helper that wraps exec-capture extracts its result via
;;   the `status-of` / `stdout-of` / `stderr-of` accessors so
;;   callers never reach into the alist shape directly.
;; - TOML-walker helpers are line-based (no full TOML parser yet);
;;   stop at the next `[section]` heading.

;; ────────────────────────────────────────────────────────────────
;; Output sink — GITHUB_OUTPUT appender
;; ────────────────────────────────────────────────────────────────

(define stdlib:gh-output (env-get "GITHUB_OUTPUT" ""))

(define (append-output line)
  (cond
    ((equal? stdlib:gh-output "") #t)  ;; no-op outside Actions
    (else
      (let ((prior (if (path-exists? stdlib:gh-output)
                     (read-file stdlib:gh-output)
                     "")))
        (write-file stdlib:gh-output (string-append prior line "\n"))))))

;; ────────────────────────────────────────────────────────────────
;; exec-capture result accessors
;; ────────────────────────────────────────────────────────────────

(define (status-of result) (alist-get result "status" -1))
(define (stdout-of result) (alist-get result "stdout" ""))
(define (stderr-of result) (alist-get result "stderr" ""))

;; ────────────────────────────────────────────────────────────────
;; TOML line walker — extract a field's quoted value from a
;; specific section. No full TOML parser yet; stop at the next
;; section heading.
;; ────────────────────────────────────────────────────────────────

(define (extract-quoted-value line)
  (let* ((dq-parts (string-split line "\""))
         (sq-parts (string-split line "'")))
    (cond
      ((>= (length dq-parts) 2) (car (cdr dq-parts)))
      ((>= (length sq-parts) 2) (car (cdr sq-parts)))
      (else ""))))

;; A TOML section header is a line wrapped in brackets — [section] or
;; [section.sub]. A TOML field assignment always contains `=`, even
;; array-valued ones like `keywords = ["a", "b"]`. The previous rule
;; (any line containing `[`) misclassified array-valued fields as
;; section headers and exited the [package] walker early — caused
;; cargo-bump to report "package.version not found" on num-traits
;; and any Cargo.toml with array fields above `version`.
(define (line-is-section-header? line)
  (let ((trimmed (string-trim line)))
    (and (> (string-length trimmed) 0)
         (string-contains? trimmed "[")
         (not (string-contains? trimmed "=")))))

;; True when a TOML line is `<field> = ...` for the EXACT field name.
;; The previous predicate used (string-contains? line field) which
;; matches `version` inside `rust-version` — produced version-unchanged
;; "1.71" instead of the real package version on caixa-mio. Strict:
;; split at first =, trim the LHS, byte-equal against field.
(define (line-assigns-field? line field)
  (let ((parts (string-split line "=")))
    (cond
      ((< (length parts) 2) #f)
      (else (equal? (string-trim (car parts)) field)))))

;; True when the trimmed line IS the named section header — i.e.
;; the line, after stripping whitespace, byte-equals 'section'.
;; Strict matching prevents false positives from array values like
;; `keywords = ["package", "tool"]` matching section "[package]", or
;; from `[package.metadata.docs.rs]` matching section "[package]".
(define (line-is-named-section? line section)
  (equal? (string-trim line) section))

;; Walk lines looking for the named section header, then return
;; the first `field = "value"` inside it. Returns "" on miss.
(define (toml-walk-field-in-section section field lines in-section)
  (cond
    ((null? lines) "")
    ((line-is-named-section? (car lines) section)
     (toml-walk-field-in-section section field (cdr lines) #t))
    ((and in-section (line-is-section-header? (car lines)))
     "")
    ((and in-section (line-assigns-field? (car lines) field))
     (extract-quoted-value (car lines)))
    (else (toml-walk-field-in-section section field (cdr lines) in-section))))

(define (toml-read-field path section field)
  (if (path-exists? path)
    (toml-walk-field-in-section section field
                                (string-split (read-file path) "\n")
                                #f)
    ""))

;; Cargo-specific shorthands.
(define (cargo-workspace-version)
  (toml-read-field "Cargo.toml" "[workspace.package]" "version"))

(define (cargo-package-version)
  (toml-read-field "Cargo.toml" "[package]" "version"))

(define (cargo-package-name)
  (toml-read-field "Cargo.toml" "[package]" "name"))

;; ────────────────────────────────────────────────────────────────
;; Cargo publish failure-mode detection — typed predicates
;; ────────────────────────────────────────────────────────────────
;; Shared between rust-workspace-publish + cargo-publish-each-member +
;; future cargo publishers. Each predicate inspects an arbitrary log
;; chunk (cargo publish's stderr/stdout merged) and returns #t if the
;; named failure-mode pattern is present.

(define (any-line-matches? lines pred)
  (cond
    ((null? lines) #f)
    ((pred (car lines)) #t)
    (else (any-line-matches? (cdr lines) pred))))

(define (cargo-publish-already-uploaded-line? line)
  (or (string-contains? line "already exists on crates.io")
      (string-contains? line "already uploaded")
      (string-contains? line "was already published")))

(define (cargo-publish-already-uploaded? log)
  (any-line-matches? (string-split log "\n") cargo-publish-already-uploaded-line?))

(define (cargo-publish-conflict-line? line)
  (or (string-contains? line "is already in use")
      (string-contains? line "is already taken")
      (string-contains? line "is already on the registry")
      (string-contains? line "crate name is not allowed")
      (string-contains? line "Unauthorized")
      (string-contains? line "denied")
      (string-contains? line "Invalid token")))

(define (cargo-publish-conflict? log)
  (any-line-matches? (string-split log "\n") cargo-publish-conflict-line?))

(define (cargo-publish-rate-limited-line? line)
  (or (string-contains? line "status 429 Too Many Requests")
      (string-contains? line "published too many new crates")
      (string-contains? line "rate-limits")
      (string-contains? line "429 Too Many")))

(define (cargo-publish-rate-limited? log)
  (any-line-matches? (string-split log "\n") cargo-publish-rate-limited-line?))

(define (cargo-publish-dep-missing-line? line)
  ;; cargo emits "no matching package named `X` found" when a workspace
  ;; dep isn't yet on the registry — i.e. the dep wasn't published
  ;; first; defer this crate + retry after a full pass.
  (or (string-contains? line "no matching package named")
      (string-contains? line "failed to select a version for")))

(define (cargo-publish-dep-missing? log)
  (any-line-matches? (string-split log "\n") cargo-publish-dep-missing-line?))

;; Classify an arbitrary cargo publish output into a typed outcome
;; symbol. Order matters — already-uploaded checked first so a crate
;; that's both 'already published' AND 'name taken by someone else'
;; reports as already-uploaded (the more specific outcome). Returns:
;;   'published         — exit 0 (caller passes status separately)
;;   'already-uploaded  — same (name, version) already on registry
;;   'conflict          — name owned by someone else / 401 / 403
;;   'rate-limited      — 429, back off and retry
;;   'dep-missing       — workspace dep not yet on registry; defer
;;   'failed            — unrecognized failure, surface to operator
(define (classify-cargo-publish-outcome log status)
  (cond
    ((= status 0) 'published)
    ((cargo-publish-already-uploaded? log) 'already-uploaded)
    ((cargo-publish-conflict? log) 'conflict)
    ((cargo-publish-rate-limited? log) 'rate-limited)
    ((cargo-publish-dep-missing? log) 'dep-missing)
    (else 'failed)))

;; ────────────────────────────────────────────────────────────────
;; git introspection
;; ────────────────────────────────────────────────────────────────

(define (last-tag)
  (let ((r (exec-capture "git" "describe" "--tags" "--abbrev=0")))
    (if (= (status-of r) 0)
      (string-trim (stdout-of r))
      "")))

(define (has-changes-since? tag paths)
  ;; tag may be "" (no prior tag); treat as "always has changes"
  ;; so first-release flows always bump.
  (cond
    ((equal? tag "") #t)
    (else
      (let* ((path-list (string-split paths " "))
             (args (append (list "diff" "--quiet" tag "HEAD" "--") path-list))
             (r (apply exec-capture (cons "git" args))))
        (not (= (status-of r) 0))))))

(define (configure-git-bot)
  (exec-check "git" "config" "user.name" "github-actions[bot]")
  (exec-check "git" "config" "user.email"
              "41898282+github-actions[bot]@users.noreply.github.com")
  ;; Docker action mode safety — runner UID rarely matches the
  ;; workspace owner; without safe.directory, git refuses every
  ;; mutation with "fatal: detected dubious ownership".
  (exec-capture "git" "config" "--global" "--add" "safe.directory" "*"))

;; ────────────────────────────────────────────────────────────────
;; Log scanning — match any line by predicate
;; ────────────────────────────────────────────────────────────────

(define (any-line-matches? lines pred)
  (cond
    ((null? lines) #f)
    ((pred (car lines)) #t)
    (else (any-line-matches? (cdr lines) pred))))

(define (log-contains? log substr)
  (any-line-matches? (string-split log "\n")
                     (lambda (line) (string-contains? line substr))))

;; ────────────────────────────────────────────────────────────────
;; HTTP existence probe (uses curl since tatara-lisp's http-get
;; raises on 404; we want a (200|404) → bool answer instead).
;; ────────────────────────────────────────────────────────────────

(define (http-200? url)
  (let* ((r (exec-capture "curl" "-s" "-o" "/dev/null" "-w" "%{http_code}" url))
         (code (stdout-of r)))
    (equal? code "200")))

;; Crates.io specific.
(define (cargo-published? name version)
  (http-200? (string-append "https://crates.io/api/v1/crates/"
                            name "/" version)))

;; npm registry (with @scope/name URL-encoding).
(define (npm-published? name version)
  (let* ((u1 (string-replace name "@" "%40"))
         (u2 (string-replace u1 "/" "%2F"))
         (url (string-append "https://registry.npmjs.org/" u2 "/" version)))
    (http-200? url)))

;; pypi version-specific JSON endpoint.
(define (pypi-published? name version)
  (http-200? (string-append "https://pypi.org/pypi/" name "/" version "/json")))

;; Helm OCI registry probe (v2 manifest endpoint).
(define (helm-published? registry name version)
  (let* ((host (string-replace registry "ghcr.io" "ghcr.io/v2"))
         (url (string-append "https://" host "/" name "/manifests/" version)))
    (http-200? url)))

;; ────────────────────────────────────────────────────────────────
;; JSON manifest field reader (uses jq via shell)
;; ────────────────────────────────────────────────────────────────

(define (json-read-field path field)
  ;; field is a jq path expression: "name" or ".dependencies.foo"
  (let ((r (exec-capture "sh" "-c"
              (string-append "jq -r '" field "' " path " 2>/dev/null"))))
    (if (= (status-of r) 0)
      (let ((v (string-trim (stdout-of r))))
        (if (equal? v "null") "" v))
      "")))

;; npm-specific shorthands.
(define (npm-package-name) (json-read-field "package.json" ".name"))
(define (npm-package-version) (json-read-field "package.json" ".version"))

;; ────────────────────────────────────────────────────────────────
;; YAML manifest field reader (uses yq via shell)
;; ────────────────────────────────────────────────────────────────

(define (yaml-read-field path field)
  (let ((r (exec-capture "sh" "-c"
              (string-append "yq '" field "' " path " 2>/dev/null"))))
    (if (= (status-of r) 0)
      (let ((v (string-trim (stdout-of r))))
        (if (equal? v "null") "" v))
      "")))

;; Helm Chart.yaml shorthands.
(define (helm-chart-name) (yaml-read-field "Chart.yaml" ".name"))
(define (helm-chart-version) (yaml-read-field "Chart.yaml" ".version"))

;; ────────────────────────────────────────────────────────────────
;; Python pyproject.toml shorthands (uses the TOML walker above)
;; ────────────────────────────────────────────────────────────────

(define (pyproject-name)
  (toml-read-field "pyproject.toml" "[project]" "name"))

(define (pyproject-version)
  (toml-read-field "pyproject.toml" "[project]" "version"))

;; ────────────────────────────────────────────────────────────────
;; .pleme-io-release.toml — per-repo defaults consumed by every
;; pleme-io action. Operators drop one config file at the repo
;; root; every action's defaults pull from the matching section.
;; Action env vars (set by the workflow) still win — config gives
;; the FALLBACK behind action.yml's `default:` field, never an
;; override.
;;
;; Section convention: [<action-name>] OR [<category>].
;; Field convention: kebab-case mirroring action.yml input names.
;;
;; Example .pleme-io-release.toml:
;;
;;   [bump]
;;   default-type = "patch"
;;   skip-when-no-source-changes = true
;;
;;   [publish]
;;   no-verify = true
;;   rename-prefix = "pleme-io-"
;;
;;   [security]
;;   fail-on-severity = "high"
;;   check-license-headers = true
;;
;;   [delivery]
;;   slack-webhook-secret = "SLACK_WEBHOOK_URL"
;; ────────────────────────────────────────────────────────────────

;; Read a field from .pleme-io-release.toml, fall back to default.
;; Uses the existing toml-read-field walker.
(define (release-config-field section field default-value)
  (cond
    ((not (path-exists? ".pleme-io-release.toml")) default-value)
    (else
      (let ((v (toml-read-field ".pleme-io-release.toml"
                                (string-append "[" section "]")
                                field)))
        (if (equal? v "") default-value v)))))

;; Resolve a value with precedence:
;;   env-var (workflow input)
;;     > .pleme-io-release.toml config
;;       > hardcoded default
(define (config-resolve env-var section field default-value)
  (let ((env-v (env-get env-var "")))
    (cond
      ((not (equal? env-v "")) env-v)
      (else (release-config-field section field default-value)))))
